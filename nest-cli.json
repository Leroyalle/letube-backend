      "entryFile": "main",
      "sourceRoot": "apps/identity/src",
      "compilerOptions": {
        "tsConfigPath": "apps/identity/tsconfig.app.json"
      }
    },
    "infra-constants": {
      "type": "library",
      "root": "libs/infra-constants",
      "entryFile": "index",
      "sourceRoot": "libs/infra-constants/src",
      "compilerOptions": {
        "tsConfigPath": "libs/infra/tsconfig.lib.json"
      }
    },
    "infra-core": {
      "type": "library",
      "root": "libs/infra-core",
      "entryFile": "index",
      "sourceRoot": "libs/infra-core/src",
      "compilerOptions": {
        "tsConfigPath": "libs/infra-core/tsconfig.lib.json"
      }
    },
    "media": {
      "type": "application",
