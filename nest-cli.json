{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "projects": {
    "abstractions": {
      "type": "library",
      "root": "libs/abstractions",
      "entryFile": "index",
      "sourceRoot": "libs/abstractions/src",
      "compilerOptions": {
        "tsConfigPath": "libs/abstractions/tsconfig.lib.json"
      }
    },
    "app-gateway": {
      "type": "application",
      "root": "apps/app-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/app-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/app-gateway/tsconfig.app.json"
      }
    },
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json"
      }
    },
    "channel": {
      "type": "application",
      "root": "apps/channel",
      "entryFile": "main",
      "sourceRoot": "apps/channel/src",
      "compilerOptions": {
        "tsConfigPath": "apps/channel/tsconfig.app.json"
      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "identity": {
      "type": "application",
