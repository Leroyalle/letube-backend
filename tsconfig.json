{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@app/abstractions": ["libs/abstractions/src"],
      "@app/abstractions/*": ["libs/abstractions/src/*"],
      "@app/infra-core": ["libs/infra-core/src"],
      "@app/infra-core/*": ["libs/infra-core/src/*"],
      "@app/modules": ["libs/modules/src"],
      "@app/modules/*": ["libs/modules/src/*"],
      "@app/pure": ["libs/pure/src"],
      "@app/pure/*": ["libs/pure/src/*"],
      "@contracts": ["libs/contracts/src"],
      "@contracts/*": ["libs/contracts/src/*"],
      "@infra": ["libs/infra-constants/src"],
      "@infra/*": ["libs/infra-constants/src/*"]
    }
  }
}
